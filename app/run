#!/bin/bash
# =============================================================================
#  Imprint  —  exécutable de l'app macOS
#
#  Au double-clic, cette app :
#    1. demande le dossier contenant les TIFF + le fichier Excel/CSV de légendes
#    2. installe ExifTool automatiquement si nécessaire (1re fois, Internet requis)
#    3. lit le tableau (colonnes "Filename" et "Description")
#    4. écrit la légende dans IPTC:Caption-Abstract + XMP-dc:Description
#       + EXIF:ImageDescription de chaque TIFF correspondant
#    5. affiche un résumé.
#
#  Aucun terminal, aucune ligne de commande pour l'utilisateur.
# =============================================================================
set -u

TITLE="Imprint"
SUPPORT="$HOME/Library/Application Support/Imprint"

# Répertoire Resources de l'app (l'exécutable est dans Contents/MacOS/)
CONTENTS="$(cd "$(dirname "$0")/.." && pwd)"
RES="$CONTENTS/Resources"
PARSER="$RES/parse_sheet.pl"

# --- petites fonctions de dialogue (natifs macOS) ---------------------------
info() { /usr/bin/osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\" with title \"$TITLE\"" >/dev/null 2>&1; }
fail() { /usr/bin/osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\" with title \"$TITLE\" with icon stop" >/dev/null 2>&1; exit 1; }
notify(){ /usr/bin/osascript -e "display notification \"$1\" with title \"$TITLE\"" >/dev/null 2>&1; }

[ -f "$PARSER" ] || fail "Fichier interne manquant (parse_sheet.pl). Réinstallez l'application."

# --- 1. Choisir le dossier ---------------------------------------------------
FOLDER="$(/usr/bin/osascript -e 'POSIX path of (choose folder with prompt "Choisissez le dossier qui contient vos photos TIFF ET votre fichier Excel (.xlsx) ou CSV de légendes :")' 2>/dev/null)"
[ -z "$FOLDER" ] && exit 0          # annulé
FOLDER="${FOLDER%/}"

# --- 2. Trouver le tableau (xlsx prioritaire, sinon csv) ---------------------
shopt -s nullglob
candidates=( "$FOLDER"/*.xlsx "$FOLDER"/*.csv )
shopt -u nullglob
# Ignorer les fichiers temporaires/verrous créés quand un classeur est ouvert
# (Excel : "~$nom.xlsx" ; LibreOffice : ".~lock.nom#"), ainsi que les fichiers cachés.
sheets=()
for f in "${candidates[@]}"; do
    b="$(basename "$f")"
    case "$b" in
        "~"*|".~"*|.*) continue ;;
    esac
    sheets+=( "$f" )
done
if [ "${#sheets[@]}" -eq 0 ]; then
    fail "Aucun fichier Excel (.xlsx) ni CSV (.csv) trouvé dans ce dossier.\n\nPlacez votre fichier de légendes dans le même dossier que les photos, puis relancez."
elif [ "${#sheets[@]}" -eq 1 ]; then
    SHEET="${sheets[0]}"
else
    # plusieurs candidats : laisser l'utilisateur choisir
    list=""
    for f in "${sheets[@]}"; do n="$(basename "$f")"; list="$list\"$n\","; done
    list="${list%,}"
    chosen="$(/usr/bin/osascript -e "set L to {$list}" -e "choose from list L with title \"$TITLE\" with prompt \"Quel fichier de légendes utiliser ?\"" 2>/dev/null)"
    [ -z "$chosen" ] || [ "$chosen" = "false" ] && exit 0
    SHEET="$FOLDER/$chosen"
fi

# --- 3. S'assurer qu'ExifTool est disponible --------------------------------
ET=""
for cand in /usr/local/bin/exiftool /opt/homebrew/bin/exiftool "$(command -v exiftool 2>/dev/null)"; do
    [ -n "$cand" ] && [ -x "$cand" ] && ET="$cand" && break
done
if [ -z "$ET" ]; then
    # déjà téléchargé une fois ?
    existing="$(ls -d "$SUPPORT"/Image-ExifTool-*/exiftool 2>/dev/null | sort -V | tail -1)"
    if [ -n "$existing" ] && [ -f "$existing" ]; then
        ET="$existing"
    else
        notify "Première utilisation : installation d'ExifTool…"
        mkdir -p "$SUPPORT"
        VER="$(/usr/bin/curl -fsSL https://exiftool.org/ver.txt 2>/dev/null | tr -d '[:space:]')"
        [ -z "$VER" ] && fail "ExifTool n'est pas installé et son téléchargement a échoué.\n\nVérifiez votre connexion Internet et relancez (l'installation n'est nécessaire qu'une seule fois)."
        TGZ="$SUPPORT/Image-ExifTool-$VER.tar.gz"
        /usr/bin/curl -fL "https://exiftool.org/Image-ExifTool-$VER.tar.gz" -o "$TGZ" 2>/dev/null \
            || fail "Téléchargement d'ExifTool impossible. Vérifiez votre connexion Internet."
        /usr/bin/tar -xzf "$TGZ" -C "$SUPPORT" 2>/dev/null \
            || fail "Décompression d'ExifTool impossible."
        ET="$SUPPORT/Image-ExifTool-$VER/exiftool"
        chmod +x "$ET" 2>/dev/null
    fi
fi
[ -f "$ET" ] || fail "ExifTool introuvable après installation."

# --- 4. Lire le tableau -> CSV compatible ExifTool ---------------------------
TMP="$(/usr/bin/mktemp /tmp/legendes.XXXXXX)"
LOG="$TMP.log"
/usr/bin/perl "$PARSER" "$FOLDER" "$SHEET" >"$TMP" 2>"$LOG" \
    || fail "Lecture du fichier de légendes impossible.\n\n$(cat "$LOG" 2>/dev/null | head -c 400)"

ASSOCIES="$(grep -m1 '^ASSOCIES='        "$LOG" | cut -d= -f2)"
NONTROUV="$(grep -m1 '^NON_TROUVES='     "$LOG" | cut -d= -f2)"
SANSLEG="$(grep -m1 '^TIF_SANS_LEGENDE=' "$LOG" | cut -d= -f2)"
ASSOCIES="${ASSOCIES:-0}"; NONTROUV="${NONTROUV:-0}"; SANSLEG="${SANSLEG:-0}"

if [ "$ASSOCIES" -eq 0 ]; then
    rm -f "$TMP" "$LOG"
    fail "Aucune photo du tableau ne correspond à un fichier .tif présent dans le dossier.\n\nVérifiez que les noms de la colonne « Filename » correspondent bien aux fichiers (ex. MR10431)."
fi

# --- 5. Écrire les légendes dans les TIFF ------------------------------------
ETOUT="$("$ET" -charset filename=UTF8 -charset iptc=UTF8 -codedcharacterset=utf8 \
    -csv="$TMP" -overwrite_original -P -ext tif -ext tiff "$FOLDER" 2>&1)"
UPDATED="$(printf '%s\n' "$ETOUT" | grep -oE '[0-9]+ image files? updated' | grep -oE '^[0-9]+')"
UPDATED="${UPDATED:-0}"

rm -f "$TMP" "$LOG"

# --- 6. Résumé ---------------------------------------------------------------
MSG="Terminé ✅\n\n• Photos légendées : $UPDATED\n• Légendes lues dans le tableau : $ASSOCIES"
[ "$NONTROUV" -gt 0 ] && MSG="$MSG\n• Lignes du tableau sans photo correspondante : $NONTROUV"
[ "$SANSLEG"  -gt 0 ] && MSG="$MSG\n• Photos .tif sans légende dans le tableau : $SANSLEG"
MSG="$MSG\n\nLa description apparaît maintenant dans le champ « Légende / Description » (Bridge, Photoshop, agences…)."

choice="$(/usr/bin/osascript -e "display dialog \"$MSG\" buttons {\"Fermer\",\"Ouvrir le dossier\"} default button \"Ouvrir le dossier\" with title \"$TITLE\"" 2>/dev/null)"
case "$choice" in
    *"Ouvrir le dossier"*) /usr/bin/open "$FOLDER" ;;
esac
exit 0
